# Terraform state (contains sensitive data)
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Terraform variables (contains secrets like API keys)
*.tfvars
!terraform.example.tfvars

# OS files
.DS_Store

# IDE files
.idea/
.vscode/
*.swp
*.swo

# Terraform values with real secrets — keep local only; use terraform.example.tfvars as template
**/terraform.tfvars
